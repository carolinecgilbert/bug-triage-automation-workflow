CHROMA_DB_DIR=chroma_db
CHROMA_COLLECTION_NAME=bug_triage_rag

# FastAPI base URL used by the Streamlit frontend and API smoke scripts.
API_BASE_URL=http://127.0.0.1:8000

# Local Dockerized Postgres for app persistence.
# Future AWS RDS migration should only require replacing this connection string
# with the RDS endpoint connection string.
DATABASE_URL=postgresql+psycopg://bugtriage:bugtriage@localhost:5432/bugtriage

# MVP default: free local embeddings with no model download.
EMBEDDING_PROVIDER=hash
HASH_EMBEDDING_DIMENSIONS=384

# Optional local semantic embeddings. Requires sentence-transformers/PyTorch.
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Optional later switch: hosted OpenAI embeddings.
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MVP default: token-free deterministic triage reasoning.
LLM_PROVIDER=mock
OPENAI_CHAT_MODEL=gpt-4.1-mini
